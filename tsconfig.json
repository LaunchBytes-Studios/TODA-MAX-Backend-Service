{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node18",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "src/prisma/prisma.config.ts", "src/controllers/patient-chat/test/.ts"],
  "exclude": ["node_modules", "dist"]
}
